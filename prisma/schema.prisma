generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A published tournament that phones sync to for live scoring.
// `data` holds the full Tournament JSON; `version` bumps on every change.
model LiveTournament {
  id        String   @id @default(cuid())
  code      String   @unique
  data      Json
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("live_tournaments")
}

// A cheer/comment posted to a live tournament's feed. Anyone in the session
// (host or spectator) can post; optionally tagged to a player or a hole.
model LiveComment {
  id          String   @id @default(cuid())
  code        String // live tournament code
  author      String
  text        String
  targetType  String? // "player" | "hole"
  targetLabel String? // e.g. "Adam" or "Hole 7"
  createdAt   DateTime @default(now())

  @@index([code, createdAt])
  @@map("live_comments")
}

// A user's tournament backed up to the cloud under their anonymous library key.
// Survives browser/storage clearing and lets a library be pulled onto other devices.
model OwnedTournament {
  id        String   @id // the tournament id
  ownerId   String // anonymous library key (per device, shareable to restore)
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([ownerId])
  @@map("owned_tournaments")
}

// Links an email to a library key so a user can recover their library on a new
// device by entering their email + a one-time code (no password / account).
model EmailLink {
  email      String   @id
  libraryKey String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("email_links")
}

// A short-lived one-time code emailed to verify ownership of an address.
model LoginCode {
  email     String   @id
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("login_codes")
}
