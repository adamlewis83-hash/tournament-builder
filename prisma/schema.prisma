generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A published tournament that phones sync to for live scoring.
// `data` holds the full Tournament JSON; `version` bumps on every change.
model LiveTournament {
  id        String   @id @default(cuid())
  code      String   @unique
  data      Json
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("live_tournaments")
}

// A user's tournament backed up to the cloud under their anonymous library key.
// Survives browser/storage clearing and lets a library be pulled onto other devices.
model OwnedTournament {
  id        String   @id // the tournament id
  ownerId   String // anonymous library key (per device, shareable to restore)
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([ownerId])
  @@map("owned_tournaments")
}
